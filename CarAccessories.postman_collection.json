{
  "info": {
    "name": "Car Accessories Catalog and Ordering Platform",
    "description": "Complete API collection for Car Accessories Catalog and Ordering Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [{ "key": "base_url", "value": "http://localhost:8000", "type": "string" }],
  "item": [
    {
      "name": "🔐 Common",
      "item": [
        { "name": "Signup", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/signup", "host": ["{{base_url}}"], "path": ["signup"] }, "body": { "mode": "raw", "raw": "{\n  \"name\": \"Karan Desai\",\n  \"email\": \"karan@gmail.com\",\n  \"phone\": \"9900000002\",\n  \"address\": \"22, Satellite Road, Ahmedabad\",\n  \"password\": \"Karan@123\"\n}" } } },
        { "name": "Login (User)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }, "body": { "mode": "raw", "raw": "{\n  \"email\": \"karan@gmail.com\",\n  \"password\": \"Karan@123\"\n}" } } },
        { "name": "Login (Admin)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }, "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@caracc.com\",\n  \"password\": \"Admin@123\"\n}" } } },
        { "name": "Logout", "request": { "method": "GET", "url": { "raw": "{{base_url}}/logout", "host": ["{{base_url}}"], "path": ["logout"] } } },
        { "name": "Session", "request": { "method": "GET", "url": { "raw": "{{base_url}}/session", "host": ["{{base_url}}"], "path": ["session"] } } },
        { "name": "Change Password", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/changePassword", "host": ["{{base_url}}"], "path": ["changePassword"] }, "body": { "mode": "raw", "raw": "{\n  \"email\": \"karan@gmail.com\",\n  \"newPassword\": \"NewPass@123\"\n}" } } }
      ]
    },
    {
      "name": "🌐 Public",
      "item": [
        { "name": "Get All Categories", "request": { "method": "GET", "url": { "raw": "{{base_url}}/categories", "host": ["{{base_url}}"], "path": ["categories"] } } },
        { "name": "Get All Products", "request": { "method": "GET", "url": { "raw": "{{base_url}}/products", "host": ["{{base_url}}"], "path": ["products"] } } },
        { "name": "Get Products — Filter by Category", "request": { "method": "GET", "url": { "raw": "{{base_url}}/products?category_id=CATEGORY_ID_HERE", "host": ["{{base_url}}"], "path": ["products"], "query": [{ "key": "category_id", "value": "CATEGORY_ID_HERE" }] } } },
        { "name": "Get Products — Filter by Price Range", "request": { "method": "GET", "url": { "raw": "{{base_url}}/products?min_price=500&max_price=3000", "host": ["{{base_url}}"], "path": ["products"], "query": [{ "key": "min_price", "value": "500" }, { "key": "max_price", "value": "3000" }] } } },
        { "name": "Get Product Details", "request": { "method": "GET", "url": { "raw": "{{base_url}}/products/PRODUCT_ID_HERE", "host": ["{{base_url}}"], "path": ["products", "PRODUCT_ID_HERE"] } } },
        { "name": "Get All Feedbacks", "request": { "method": "GET", "url": { "raw": "{{base_url}}/feedbacks", "host": ["{{base_url}}"], "path": ["feedbacks"] } } }
      ]
    },
    {
      "name": "🟢 User (Session Required)",
      "item": [
        { "name": "Get Profile", "request": { "method": "GET", "url": { "raw": "{{base_url}}/user/profile", "host": ["{{base_url}}"], "path": ["user", "profile"] } } },
        { "name": "Update Profile (with image)", "request": { "method": "POST", "url": { "raw": "{{base_url}}/user/updateProfile", "host": ["{{base_url}}"], "path": ["user", "updateProfile"] }, "body": { "mode": "formdata", "formdata": [{ "key": "name", "value": "Karan Kumar Desai", "type": "text" }, { "key": "phone", "value": "9911111111", "type": "text" }, { "key": "address", "value": "New CG Road, Ahmedabad", "type": "text" }, { "key": "profile_image", "src": "", "type": "file" }] } } },
        { "name": "Place Order", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/user/placeOrder", "host": ["{{base_url}}"], "path": ["user", "placeOrder"] }, "body": { "mode": "raw", "raw": "{\n  \"product_id\": \"PRODUCT_ID_HERE\",\n  \"quantity\": 2\n}" } } },
        { "name": "My Orders", "request": { "method": "GET", "url": { "raw": "{{base_url}}/user/myOrders", "host": ["{{base_url}}"], "path": ["user", "myOrders"] } } },
        { "name": "Cancel Order", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/user/cancelOrder", "host": ["{{base_url}}"], "path": ["user", "cancelOrder"] }, "body": { "mode": "raw", "raw": "{\n  \"order_id\": \"ORDER_ID_HERE\"\n}" } } },
        { "name": "Generate Razorpay Order ID", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/user/genOrderId", "host": ["{{base_url}}"], "path": ["user", "genOrderId"] }, "body": { "mode": "raw", "raw": "{\n  \"order_id\": \"ORDER_ID_HERE\"\n}" } } },
        { "name": "Verify Razorpay Payment", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/user/verifyPayment", "host": ["{{base_url}}"], "path": ["user", "verifyPayment"] }, "body": { "mode": "raw", "raw": "{\n  \"order_id\": \"ORDER_ID_HERE\",\n  \"razorpay_order_id\": \"order_XXXX\",\n  \"razorpay_payment_id\": \"pay_XXXX\",\n  \"razorpay_signature\": \"sig_XXXX\"\n}" } } },
        { "name": "Add Feedback", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/user/addFeedback", "host": ["{{base_url}}"], "path": ["user", "addFeedback"] }, "body": { "mode": "raw", "raw": "{\n  \"booking_id\": \"ORDER_ID_HERE\",\n  \"rating\": 5,\n  \"feedback\": \"Very good service and affordable price. Excellent product quality!\"\n}" } } }
      ]
    },
    {
      "name": "🔴 Admin (Session Required)",
      "item": [
        { "name": "Get All Users", "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/users", "host": ["{{base_url}}"], "path": ["admin", "users"] } } },
        { "name": "Update User Status (Activate)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/admin/updateUserStatus", "host": ["{{base_url}}"], "path": ["admin", "updateUserStatus"] }, "body": { "mode": "raw", "raw": "{\n  \"user_id\": \"USER_ID_HERE\",\n  \"status\": \"Active\"\n}" } } },
        { "name": "Update User Status (Deactivate)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/admin/updateUserStatus", "host": ["{{base_url}}"], "path": ["admin", "updateUserStatus"] }, "body": { "mode": "raw", "raw": "{\n  \"user_id\": \"USER_ID_HERE\",\n  \"status\": \"Inactive\"\n}" } } },
        { "name": "Add Category", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/admin/addCategory", "host": ["{{base_url}}"], "path": ["admin", "addCategory"] }, "body": { "mode": "raw", "raw": "{\n  \"name\": \"Interior\"\n}" } } },
        { "name": "Update Category", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/admin/updateCategory", "host": ["{{base_url}}"], "path": ["admin", "updateCategory"] }, "body": { "mode": "raw", "raw": "{\n  \"id\": \"CATEGORY_ID_HERE\",\n  \"name\": \"Car Interior\",\n  \"status\": \"Active\"\n}" } } },
        { "name": "Delete Category", "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/deleteCategory/CATEGORY_ID_HERE", "host": ["{{base_url}}"], "path": ["admin", "deleteCategory", "CATEGORY_ID_HERE"] } } },
        { "name": "Get All Categories (Admin)", "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/categories", "host": ["{{base_url}}"], "path": ["admin", "categories"] } } },
        { "name": "Add Product (with image)", "request": { "method": "POST", "url": { "raw": "{{base_url}}/admin/addProduct", "host": ["{{base_url}}"], "path": ["admin", "addProduct"] }, "body": { "mode": "formdata", "formdata": [{ "key": "category_id", "value": "CATEGORY_ID_HERE", "type": "text" }, { "key": "name", "value": "Premium Leather Seat Cover", "type": "text" }, { "key": "description", "value": "High quality waterproof leather seat cover", "type": "text" }, { "key": "specification", "value": "Waterproof, Anti-slip, Universal fit", "type": "text" }, { "key": "stock", "value": "50", "type": "text" }, { "key": "price", "value": "2500", "type": "text" }, { "key": "image", "src": "", "type": "file" }] } } },
        { "name": "Update Product (with image)", "request": { "method": "POST", "url": { "raw": "{{base_url}}/admin/updateProduct", "host": ["{{base_url}}"], "path": ["admin", "updateProduct"] }, "body": { "mode": "formdata", "formdata": [{ "key": "id", "value": "PRODUCT_ID_HERE", "type": "text" }, { "key": "price", "value": "2800", "type": "text" }, { "key": "stock", "value": "45", "type": "text" }, { "key": "status", "value": "Available", "type": "text" }, { "key": "image", "src": "", "type": "file" }] } } },
        { "name": "Delete Product", "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/deleteProduct/PRODUCT_ID_HERE", "host": ["{{base_url}}"], "path": ["admin", "deleteProduct", "PRODUCT_ID_HERE"] } } },
        { "name": "Get All Products (Admin)", "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/products", "host": ["{{base_url}}"], "path": ["admin", "products"] } } },
        { "name": "Get All Orders", "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/orders", "host": ["{{base_url}}"], "path": ["admin", "orders"] } } },
        { "name": "Update Order Status (Shipped)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/admin/updateOrderStatus", "host": ["{{base_url}}"], "path": ["admin", "updateOrderStatus"] }, "body": { "mode": "raw", "raw": "{\n  \"id\": \"ORDER_ID_HERE\",\n  \"status\": \"Shipped\"\n}" } } },
        { "name": "Update Order Status (Delivered)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/admin/updateOrderStatus", "host": ["{{base_url}}"], "path": ["admin", "updateOrderStatus"] }, "body": { "mode": "raw", "raw": "{\n  \"id\": \"ORDER_ID_HERE\",\n  \"status\": \"Delivered\"\n}" } } },
        { "name": "Update Order Status (Cancel)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/admin/updateOrderStatus", "host": ["{{base_url}}"], "path": ["admin", "updateOrderStatus"] }, "body": { "mode": "raw", "raw": "{\n  \"id\": \"ORDER_ID_HERE\",\n  \"status\": \"Cancelled\"\n}" } } },
        { "name": "Get All Payments", "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/payments", "host": ["{{base_url}}"], "path": ["admin", "payments"] } } },
        { "name": "Get All Feedbacks (Admin)", "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/feedbacks", "host": ["{{base_url}}"], "path": ["admin", "feedbacks"] } } },
        { "name": "Dashboard Stats", "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/dashboardStats", "host": ["{{base_url}}"], "path": ["admin", "dashboardStats"] } } }
      ]
    }
  ]
}
